# Copy to web/.env, then:  cd web && docker compose up -d
# (docker compose auto-loads web/.env when run from this directory.)

# Public HTTPS hostname for the server list. It MUST have a DNS A record pointing
# at this host, and TCP 443 must be reachable. Caddy fetches the cert for it.
DC_WEB_DOMAIN=dealers-choice-foss.dev

# Host directory the registry writes servers.json to (its DC_REGISTRY_DIR). It
# must be a host PATH so this stack can read it. Defaults to /srv/www.
#DC_WEB_ROOT=/srv/www
